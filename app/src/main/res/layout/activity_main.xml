<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <FrameLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/wallpaper_surface"
        tools:context=".presenter.components.main.MainActivity">

        <!-- Background gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_main_gradient" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="60dp"
                android:paddingHorizontal="24dp"
                android:paddingBottom="32dp"
                android:gravity="center_horizontal">

                <!-- App header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Wallpaper Studio"
                    android:textColor="@color/wallpaper_accent"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp"
                    android:alpha="0.8" />

                <!-- ======================== -->
                <!-- CARD 1: Clownfish (GLTF) -->
                <!-- ======================== -->
                <FrameLayout
                    android:id="@+id/cardGltf"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_preview_card"
                    android:clipChildren="true"
                    android:clipToPadding="false"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivPreviewGltf"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:alpha="0.7"
                        android:contentDescription="@string/clownfish_title" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_card_overlay" />

                    <!-- Format badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:text="@string/format_gltf"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_play_button"
                        android:alpha="0.9" />

                    <!-- Card info at bottom -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clownfish_title"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/clownfish_subtitle"
                            android:textColor="@color/wallpaper_on_surface"
                            android:textSize="12sp" />
                    </LinearLayout>

                </FrameLayout>

                <!-- Buttons for GLTF card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreviewGltf"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/preview_wallpaper"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_play_preview"
                        app:iconTint="@android:color/white"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:strokeColor="@color/wallpaper_accent"
                        app:strokeWidth="1dp"
                        app:rippleColor="@color/wallpaper_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetGltf"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/set_wallpaper"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_wallpaper"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:backgroundTint="@color/wallpaper_apply_button" />

                </LinearLayout>

                <!-- ========================= -->
                <!-- CARD 2: Goldfish (G3DB)   -->
                <!-- ========================= -->
                <FrameLayout
                    android:id="@+id/cardG3db"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_preview_card"
                    android:clipChildren="true"
                    android:clipToPadding="false"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivPreviewG3db"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:alpha="0.7"
                        android:contentDescription="@string/goldfish_title" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_card_overlay" />

                    <!-- Format badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:text="@string/format_g3db"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_play_button"
                        android:alpha="0.9" />

                    <!-- Card info at bottom -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/goldfish_title"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/goldfish_subtitle"
                            android:textColor="@color/wallpaper_on_surface"
                            android:textSize="12sp" />
                    </LinearLayout>

                </FrameLayout>

                <!-- Buttons for G3DB card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreviewG3db"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/preview_wallpaper"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_play_preview"
                        app:iconTint="@android:color/white"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:strokeColor="@color/wallpaper_accent"
                        app:strokeWidth="1dp"
                        app:rippleColor="@color/wallpaper_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetG3db"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/set_wallpaper"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_wallpaper"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:backgroundTint="@color/wallpaper_apply_button" />

                </LinearLayout>

                <!-- ========================= -->
                <!-- CARD 3: Test Fish (GLTF) -->
                <!-- ========================= -->
                <FrameLayout
                    android:id="@+id/cardTestFish"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_preview_card"
                    android:clipChildren="true"
                    android:clipToPadding="false"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivPreviewTestFish"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:alpha="0.7"
                        android:contentDescription="@string/test_fish_title" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_card_overlay" />

                    <!-- Format badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:text="@string/format_gltf"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_play_button"
                        android:alpha="0.9" />

                    <!-- Card info at bottom -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/test_fish_title"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/test_fish_subtitle"
                            android:textColor="@color/wallpaper_on_surface"
                            android:textSize="12sp" />
                    </LinearLayout>

                </FrameLayout>

                <!-- Buttons for Test Fish card -->
                <!-- Buttons for Test Fish card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreviewTestFish"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/preview_wallpaper"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_play_preview"
                        app:iconTint="@android:color/white"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:strokeColor="@color/wallpaper_accent"
                        app:strokeWidth="1dp"
                        app:rippleColor="@color/wallpaper_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetTestFish"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/set_wallpaper"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_wallpaper"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:backgroundTint="@color/wallpaper_apply_button" />

                </LinearLayout>

                <!-- ========================= -->
                <!-- CARD 4: Red Devil (Video) -->
                <!-- ========================= -->
                <FrameLayout
                    android:id="@+id/cardRedDevil"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_preview_card"
                    android:clipChildren="true"
                    android:clipToPadding="false"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivPreviewRedDevil"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:alpha="0.7"
                        android:contentDescription="@string/red_devil_title" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_card_overlay" />

                    <!-- Format badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:text="@string/format_video"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_play_button"
                        android:alpha="0.9" />

                    <!-- Card info at bottom -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/red_devil_title"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/red_devil_subtitle"
                            android:textColor="@color/wallpaper_on_surface"
                            android:textSize="12sp" />
                    </LinearLayout>

                </FrameLayout>

                <!-- Buttons for Red Devil card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreviewRedDevil"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/preview_wallpaper"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_play_preview"
                        app:iconTint="@android:color/white"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:strokeColor="@color/wallpaper_accent"
                        app:strokeWidth="1dp"
                        app:rippleColor="@color/wallpaper_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetRedDevil"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/set_wallpaper"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_wallpaper"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:backgroundTint="@color/wallpaper_apply_button" />

                </LinearLayout>

                <!-- Wallpaper info section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_preview_card"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Features"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="• Realistic 3D fish with smooth animations\n• Dynamic water ripple effects on touch\n• Shadow mapping for depth perception\n• Responsive to screen orientation\n• Battery-efficient rendering"
                        android:textColor="@color/wallpaper_on_surface"
                        android:textSize="13sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</layout>